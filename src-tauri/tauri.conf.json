{
  "productName": "Garage CRM",
  "version": "1.1.3",
  "identifier": "com.garagecrm.app",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Garage CRM",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "garagecrm"
          ],
          "host": "auth",
          "pathPrefix": [
            "/callback"
          ],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": [
          "garagecrm"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0RTg3NzBFQjM3MTNGQgpSV1Q3RXpmcmNJZE9Ddzd1cW9aRHA0T203OHYwcm45M2NBT0xsckhKWGd6U2JGaW4wTWs1emlnMgo=",
      "endpoints": [
        "https://github.com/Hlopowod/GarageCRM/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
