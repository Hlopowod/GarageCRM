VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Optional. Leave empty to use the Supabase Auth Site URL.
VITE_AUTH_REDIRECT_URL=
# Optional. For web hosting, leave empty or set to https://your-domain/.
# For desktop-only builds, this can be garagecrm://auth/callback.
VITE_PASSWORD_RESET_REDIRECT_URL=

# Supabase Edge Function secrets. Set these with:
# supabase secrets set KEY=value
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# New pricing model:
STRIPE_PRICE_SERVICE_BAY=
STRIPE_PRICE_FULL_WORKSHOP=
STRIPE_PRICE_GARAGE_EMPIRE=
# Backward-compatible aliases. Service Bay falls back to BASIC and Garage Empire falls back to ULTIMATE if the new names are empty.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_ULTIMATE=
APP_URL=

GARAGE_CRM_UPDATER_ENDPOINT=https://github.com/Hlopowod/GarageCRM/releases/latest/download/latest.json
GARAGE_CRM_UPDATER_PUBKEY_PATH=C:\path\to\garage-crm-updater.pub
